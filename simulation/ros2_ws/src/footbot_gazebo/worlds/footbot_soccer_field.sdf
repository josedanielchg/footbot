<?xml version="1.0"?>
<sdf version="1.8">
  <world name="footbot_soccer_field">
    <gravity>0 0 -9.81</gravity>
    <magnetic_field>0 0 0</magnetic_field>
    <atmosphere type="adiabatic"/>

    <plugin filename="ignition-gazebo-physics-system" name="ignition::gazebo::systems::Physics"/>
    <plugin filename="libfootbot_ball_drag_system.so" name="footbot_gazebo::BallDragSystem">
      <link_name>ball_link</link_name>
      <linear_damping>0.18</linear_damping>
      <angular_damping>0.0012</angular_damping>
      <max_force>0.30</max_force>
      <max_torque>0.015</max_torque>
      <stop_linear_speed>0.02</stop_linear_speed>
      <stop_angular_speed>0.35</stop_angular_speed>
    </plugin>
    <plugin filename="ignition-gazebo-user-commands-system" name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system" name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-sensors-system" name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <physics name="default_physics" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <scene>
      <ambient>0.65 0.65 0.65 1</ambient>
      <background>0.72 0.78 0.84 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 6 0 0 0</pose>
      <diffuse>0.92 0.92 0.92 1</diffuse>
      <specular>0.20 0.20 0.20 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.3 0.2 -0.9</direction>
    </light>

    <model name="soccer_field">
      <static>true</static>
      <link name="field_link">
        <collision name="field_collision">
          <geometry>
            <box>
              <size>4.20 2.60 0.02</size>
            </box>
          </geometry>
        </collision>
        <visual name="field_turf">
          <pose>0 0 0.001 0 0 0</pose>
          <geometry>
            <box>
              <size>4.20 2.60 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.04 0.36 0.12 1</ambient>
            <diffuse>0.04 0.48 0.16 1</diffuse>
          </material>
        </visual>
        <visual name="center_line">
          <pose>0 0 0.014 0 0 0</pose>
          <geometry>
            <box>
              <size>0.020 2.45 0.006</size>
            </box>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.90 1</ambient>
            <diffuse>0.95 0.95 0.90 1</diffuse>
          </material>
        </visual>
        <visual name="center_spot">
          <pose>0 0 0.016 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.055</radius>
              <length>0.007</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.90 1</ambient>
            <diffuse>0.95 0.95 0.90 1</diffuse>
          </material>
        </visual>
        <visual name="left_goal_box_line">
          <pose>-1.78 0 0.014 0 0 0</pose>
          <geometry>
            <box>
              <size>0.015 0.95 0.006</size>
            </box>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.90 1</ambient>
            <diffuse>0.95 0.95 0.90 1</diffuse>
          </material>
        </visual>
        <visual name="right_goal_box_line">
          <pose>1.78 0 0.014 0 0 0</pose>
          <geometry>
            <box>
              <size>0.015 0.95 0.006</size>
            </box>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.90 1</ambient>
            <diffuse>0.95 0.95 0.90 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="field_walls">
      <static>true</static>
      <link name="walls_link">
        <collision name="north_wall_collision">
          <pose>0 1.33 0.08 0 0 0</pose>
          <geometry><box><size>4.35 0.06 0.16</size></box></geometry>
        </collision>
        <visual name="north_wall">
          <pose>0 1.33 0.08 0 0 0</pose>
