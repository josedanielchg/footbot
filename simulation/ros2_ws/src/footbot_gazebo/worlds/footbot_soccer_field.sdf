        <visual name="upper_post"><pose>2.02 0.35 0.22 0 0 0</pose><geometry><box><size>0.05 0.05 0.40</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material></visual>
        <visual name="lower_post"><pose>2.02 -0.35 0.22 0 0 0</pose><geometry><box><size>0.05 0.05 0.40</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material></visual>
      </link>
    </model>

    <model name="center_ball">
      <static>false</static>
      <pose>0 0 0.045 0 0 0</pose>
      <link name="ball_link">
        <inertial>
          <mass>0.04</mass>
          <inertia><ixx>0.0000324</ixx><iyy>0.0000324</iyy><izz>0.0000324</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <velocity_decay><linear>1.20</linear><angular>2.00</angular></velocity_decay>
        <collision name="ball_collision">
          <geometry><sphere><radius>0.045</radius></sphere></geometry>
          <surface>
            <friction>
              <torsional><coefficient>1.0</coefficient><use_patch_radius>true</use_patch_radius><patch_radius>0.025</patch_radius><surface_radius>0.045</surface_radius><ode><slip>0.0</slip></ode></torsional>
              <ode><mu>2.0</mu><mu2>2.0</mu2></ode>
              <bullet><friction>2.0</friction><friction2>2.0</friction2><rolling_friction>0.8</rolling_friction></bullet>
            </friction>
            <bounce><restitution_coefficient>0.05</restitution_coefficient><threshold>0.05</threshold></bounce>
          </surface>
        </collision>
        <visual name="ball_visual">
          <geometry><sphere><radius>0.045</radius></sphere></geometry>
          <material><ambient>1.0 0.38 0.0 1</ambient><diffuse>1.0 0.38 0.0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="blue_goalkeeper">
      <static>true</static>
      <pose>-1.65 0 0 0 0 0</pose>
      <link name="robot_body">
        <collision name="base_collision"><pose>0 0 0.04 0 0 0</pose><geometry><box><size>0.24 0.19 0.06</size></box></geometry></collision>
        <visual name="base"><pose>0 0 0.04 0 0 0</pose><geometry><box><size>0.24 0.19 0.06</size></box></geometry><material><ambient>0.05 0.22 0.75 1</ambient><diffuse>0.05 0.22 0.75 1</diffuse></material></visual>
        <visual name="top_plate"><pose>0.03 0 0.074 0 0 0</pose><geometry><box><size>0.17 0.17 0.008</size></box></geometry><material><ambient>0.72 0.74 0.76 1</ambient><diffuse>0.72 0.74 0.76 1</diffuse></material></visual>
        <visual name="front_panel"><pose>0.112 0 0.034 0 0 0</pose><geometry><box><size>0.012 0.19 0.04</size></box></geometry><material><ambient>0.55 0.57 0.59 1</ambient><diffuse>0.55 0.57 0.59 1</diffuse></material></visual>
        <visual name="left_wheel"><pose>0.035 0.105 0.04 1.5708 0 0</pose><geometry><cylinder><radius>0.04</radius><length>0.024</length></cylinder></geometry><material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.02 0.02 0.02 1</diffuse></material></visual>
        <visual name="right_wheel"><pose>0.035 -0.105 0.04 1.5708 0 0</pose><geometry><cylinder><radius>0.04</radius><length>0.024</length></cylinder></geometry><material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.02 0.02 0.02 1</diffuse></material></visual>
        <visual name="camera"><pose>0.025 0 0.104 0 -0.35 0</pose><geometry><box><size>0.055 0.045 0.035</size></box></geometry><material><ambient>0.12 0.78 0.24 1</ambient><diffuse>0.12 0.78 0.24 1</diffuse></material></visual>
        <visual name="lens"><pose>0.044 0 0.102 0 -0.35 0</pose><geometry><box><size>0.020 0.032 0.018</size></box></geometry><material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.02 0.02 0.02 1</diffuse></material></visual>
        <sensor name="blue_goalkeeper_camera" type="camera">
          <pose>0.080 0 0.115 0 0 0</pose>
          <always_on>true</always_on>
          <update_rate>15</update_rate>
          <visualize>true</visualize>
          <topic>/soccer/camera/image_raw</topic>
          <camera name="blue_goalkeeper_camera">
            <camera_info_topic>/soccer/camera/camera_info</camera_info_topic>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.05</near>
              <far>8.0</far>
            </clip>
          </camera>
        </sensor>
      </link>
    </model>

