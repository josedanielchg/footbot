        </visual>
        <collision name="west_wall_collision">
          <pose>-2.18 0 0.08 0 0 0</pose>
          <geometry><box><size>0.06 2.72 0.16</size></box></geometry>
        </collision>
        <visual name="west_wall">
          <pose>-2.18 0 0.08 0 0 0</pose>
          <geometry><box><size>0.06 2.72 0.16</size></box></geometry>
          <material><ambient>0.82 0.84 0.86 1</ambient><diffuse>0.82 0.84 0.86 1</diffuse></material>
        </visual>
        <collision name="east_wall_collision">
          <pose>2.18 0 0.08 0 0 0</pose>
          <geometry><box><size>0.06 2.72 0.16</size></box></geometry>
        </collision>
        <visual name="east_wall">
          <pose>2.18 0 0.08 0 0 0</pose>
          <geometry><box><size>0.06 2.72 0.16</size></box></geometry>
          <material><ambient>0.82 0.84 0.86 1</ambient><diffuse>0.82 0.84 0.86 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="left_goal">
      <static>true</static>
      <link name="goal_link">
        <visual name="back_bar"><pose>-2.05 0 0.23 0 0 0</pose><geometry><box><size>0.04 0.70 0.06</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material></visual>
        <visual name="top_bar"><pose>-2.02 0 0.43 0 0 0</pose><geometry><box><size>0.05 0.70 0.05</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material></visual>
