<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="footbot">
  <xacro:arg name="cmd_vel_topic" default="/cmd_vel"/>
  <xacro:arg name="camera_image_topic" default="/camera/image_raw"/>
  <xacro:arg name="camera_info_topic" default="/camera/camera_info"/>
  <xacro:arg name="camera_frame_id" default="camera_optical_frame"/>

  <xacro:property name="base_length" value="0.24"/>
  <xacro:property name="base_width" value="0.19"/>
  <xacro:property name="base_height" value="0.06"/>
  <xacro:property name="base_mass" value="0.90"/>

  <xacro:property name="wheel_radius" value="0.040"/>
  <xacro:property name="wheel_thickness" value="0.024"/>
  <xacro:property name="wheel_mass" value="0.06"/>
  <xacro:property name="wheel_x" value="0.035"/>
  <xacro:property name="wheel_y" value="0.105"/>
  <xacro:property name="wheel_z_from_base" value="0.000"/>

  <xacro:property name="camera_length" value="0.055"/>
  <xacro:property name="camera_width" value="0.045"/>
  <xacro:property name="camera_height" value="0.035"/>
  <xacro:property name="camera_mass" value="0.02"/>
  <xacro:property name="camera_optical_frame_mass" value="0.001"/>

  <xacro:property name="caster_radius" value="0.010"/>
  <xacro:property name="caster_mass" value="0.01"/>
  <xacro:property name="caster_x" value="-0.095"/>
  <xacro:property name="caster_z_from_base" value="-0.030"/>

  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass / 12.0 * (y * y + z * z)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass / 12.0 * (x * x + z * z)}"
        iyz="0.0"
        izz="${mass / 12.0 * (x * x + y * y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="wheel_inertial" params="mass radius thickness">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass / 12.0 * (3.0 * radius * radius + thickness * thickness)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass / 2.0 * radius * radius}"
        iyz="0.0"
        izz="${mass / 12.0 * (3.0 * radius * radius + thickness * thickness)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertial" params="mass radius">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${2.0 / 5.0 * mass * radius * radius}"
        ixy="0.0"
        ixz="0.0"
        iyy="${2.0 / 5.0 * mass * radius * radius}"
        iyz="0.0"
        izz="${2.0 / 5.0 * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="footbot_blue">
        <color rgba="0.45 0.50 0.55 1.0"/>
      </material>
    </visual>
    <visual>
      <origin xyz="0.030 0 ${base_height / 2.0 + 0.004}" rpy="0 0 0"/>
      <geometry>
        <box size="0.170 0.170 0.008"/>
      </geometry>
      <material name="top_plate_gray">
        <color rgba="0.68 0.70 0.72 1.0"/>
      </material>
    </visual>
    <visual>
      <origin xyz="${base_length / 2.0 - 0.008} 0 -0.006" rpy="0 0 0"/>
      <geometry>
        <box size="0.012 ${base_width} 0.040"/>
      </geometry>
      <material name="front_panel_gray">
        <color rgba="0.60 0.63 0.65 1.0"/>
      </material>
    </visual>
    <visual>
      <origin xyz="-0.030 ${base_width / 2.0 - 0.008} -0.002" rpy="0 0 0"/>
      <geometry>
        <box size="0.150 0.010 0.070"/>
      </geometry>
      <material name="side_panel_gray">
        <color rgba="0.56 0.59 0.61 1.0"/>
      </material>
    </visual>
    <visual>
      <origin xyz="-0.030 -${base_width / 2.0 - 0.008} -0.002" rpy="0 0 0"/>
      <geometry>
        <box size="0.150 0.010 0.070"/>
      </geometry>
      <material name="side_panel_gray"/>
    </visual>
    <visual>
      <origin xyz="-0.080 0 -0.004" rpy="0 0 0"/>
      <geometry>
        <box size="0.055 0.120 0.032"/>
      </geometry>
      <material name="rear_support_gray">
        <color rgba="0.50 0.53 0.55 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="${wheel_x} ${wheel_y} ${wheel_z_from_base}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.02 0.02 0.02 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <xacro:wheel_inertial mass="${wheel_mass}" radius="${wheel_radius}" thickness="${wheel_thickness}"/>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="${wheel_x} -${wheel_y} ${wheel_z_from_base}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <xacro:wheel_inertial mass="${wheel_mass}" radius="${wheel_radius}" thickness="${wheel_thickness}"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.025 0 ${base_height / 2.0 + 0.034}" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 -0.35 0"/>
      <geometry>
        <box size="${camera_length} ${camera_width} ${camera_height}"/>
      </geometry>
      <material name="camera_green">
        <color rgba="0.22 0.70 0.34 1.0"/>
      </material>
    </visual>
    <visual>
      <origin xyz="0.018 0 -0.002" rpy="0 -0.35 0"/>
      <geometry>
        <box size="0.020 0.032 0.018"/>
      </geometry>
      <material name="camera_lens">
        <color rgba="0.04 0.05 0.05 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_length} ${camera_width} ${camera_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="${camera_mass}" x="${camera_length}" y="${camera_width}" z="${camera_height}"/>
  </link>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="${camera_length / 2.0} 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <link name="camera_optical_frame">
    <xacro:box_inertial
      mass="${camera_optical_frame_mass}"
      x="0.001"
      y="0.001"
      z="0.001"/>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="${caster_x} 0 ${caster_z_from_base}" rpy="0 0 0"/>
  </joint>

  <link name="caster_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="caster_gray">
        <color rgba="0.45 0.45 0.45 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
  </link>

  <gazebo reference="camera_link">
    <sensor name="footbot_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>true</visualize>
      <topic>$(arg camera_image_topic)</topic>
      <camera name="footbot_camera">
        <camera_info_topic>$(arg camera_info_topic)</camera_info_topic>
        <optical_frame_id>$(arg camera_frame_id)</optical_frame_id>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.0</stddev>
        </noise>
      </camera>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin
      filename="ignition-gazebo-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${2.0 * wheel_y}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>$(arg cmd_vel_topic)</topic>
      <max_linear_velocity>0.30</max_linear_velocity>
      <min_linear_velocity>-0.30</min_linear_velocity>
      <max_angular_velocity>1.5</max_angular_velocity>
      <min_angular_velocity>-1.5</min_angular_velocity>
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <min_linear_acceleration>-0.5</min_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <min_angular_acceleration>-2.0</min_angular_acceleration>
    </plugin>
  </gazebo>
</robot>
